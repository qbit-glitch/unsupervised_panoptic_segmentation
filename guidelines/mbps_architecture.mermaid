```mermaid
%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#E3F2FD', 'primaryTextColor': '#1A237E', 'primaryBorderColor': '#1976D2', 'lineColor': '#37474F', 'secondaryColor': '#FFF3E0', 'tertiaryColor': '#F3E5F5'}}}%%

flowchart TB
    subgraph INPUT["📥 Input"]
        RGB["🖼️ RGB Image<br/>H×W×3"]
        DEPTH["📊 Depth Map<br/>ZoeDepth"]
    end

    subgraph BACKBONE["🦖 DINO ViT-S/8 (Frozen)"]
        PATCH["Patch Embedding"]
        TRANS["Transformer ×12"]
        FEAT["F ∈ ℝ^(N×384)"]
        PATCH --> TRANS --> FEAT
    end

    subgraph SEMANTIC["🟠 Semantic Branch (DepthG)"]
        SEM_HEAD["Semantic Head"]
        SEM_CODE["S ∈ ℝ^(N×90)"]
        SEM_HEAD --> SEM_CODE
    end

    subgraph INSTANCE["🟣 Instance Branch (CutS3D)"]
        NCUT["NCut + LocalCut 3D"]
        INST_FEAT["F_inst ∈ ℝ^(N×384)"]
        NCUT --> INST_FEAT
    end

    subgraph BRIDGE["🔵 Adaptive Projection Bridge"]
        PROJ_S["W_s: 90 → D_b"]
        PROJ_F["W_f: 384 → D_b"]
        ALIGNED["S', F' ∈ ℝ^(N×192)"]
        PROJ_S --> ALIGNED
        PROJ_F --> ALIGNED
    end

    subgraph DEPTH_COND["⬛ Unified Depth Conditioning"]
        DEPTH_ENC["Depth Encoder"]
        GATES["Gated Conditioning"]
        COND_OUT["S_d, F_d"]
        DEPTH_ENC --> GATES --> COND_OUT
    end

    subgraph MAMBA["🔴 Mamba2 Bridge (TPU-SSD)"]
        INTERLEAVE["Interleave<br/>[S₁,F₁,S₂,F₂,...]"]
        FWD["Forward Scan →<br/>Y_fwd = SSM(Z)"]
        BWD["← Backward Scan<br/>Y_bwd = SSM(rev(Z))"]
        BICMS["BiCMS Fusion<br/>W[Y_fwd; Y_bwd] + Z"]
        DEINTER["Deinterleave"]
        FUSED["S_fused, F_fused"]
        
        INTERLEAVE --> FWD
        INTERLEAVE --> BWD
        FWD --> BICMS
        BWD --> BICMS
        BICMS --> DEINTER --> FUSED
    end

    subgraph INV_PROJ["🔄 Inverse Projections"]
        INV_S["W_s†: D_b → 90<br/>S_out"]
        INV_F["W_f†: D_b → 384<br/>F_out"]
    end

    subgraph HEADS["🎯 Prediction Heads"]
        KMEANS["K-Means + CRF<br/>Sem_pred"]
        INST_HEAD["Instance Head<br/>Masks, Scores"]
    end

    subgraph STC["🟢 Stuff-Things Classifier"]
        DBD["DBD: Depth Boundary"]
        FCC["FCC: Feature Compact"]
        IDF["IDF: Instance Decomp"]
        MLP["MLP(3→16→8→1)"]
        ST_OUT["Things / Stuff"]
        
        DBD --> MLP
        FCC --> MLP
        IDF --> MLP
        MLP --> ST_OUT
    end

    subgraph MERGER["🟧 Panoptic Merger"]
        MERGE["Combine Stuff + Things"]
        PANOPTIC["Panoptic Output<br/>P = (id, class)^(H×W)"]
        MERGE --> PANOPTIC
    end

    subgraph LOSSES["📉 Loss Functions"]
        L_SEM["L_semantic<br/>STEGO + DepthG"]
        L_INST["L_instance<br/>BCE_CW + Drop"]
        L_BRIDGE["L_bridge<br/>Recon + CKA"]
        L_CONSIST["L_consistency<br/>Uniform + Boundary"]
        L_PQ["L_PQ<br/>Diff. PQ Proxy"]
        L_TOTAL["L_total = α·L_sem + β·L_inst + γ·L_bridge + δ·L_consist + ε·L_PQ"]
        
        L_SEM --> L_TOTAL
        L_INST --> L_TOTAL
        L_BRIDGE --> L_TOTAL
        L_CONSIST --> L_TOTAL
        L_PQ --> L_TOTAL
    end

    %% Main flow
    RGB --> BACKBONE
    FEAT --> SEMANTIC
    FEAT --> INSTANCE
    SEM_CODE --> BRIDGE
    INST_FEAT --> BRIDGE
    DEPTH --> DEPTH_COND
    ALIGNED --> DEPTH_COND
    COND_OUT --> MAMBA
    FUSED --> INV_PROJ
    INV_S --> KMEANS
    INV_F --> INST_HEAD
    KMEANS --> STC
    INST_HEAD --> STC
    KMEANS --> MERGER
    INST_HEAD --> MERGER
    ST_OUT --> MERGER

    %% Depth guidance (dashed)
    DEPTH -.->|"Depth Guidance"| SEMANTIC
    DEPTH -.->|"3D Point Cloud"| INSTANCE

    %% Loss connections
    SEM_CODE -.-> L_SEM
    INST_FEAT -.-> L_INST
    FUSED -.-> L_BRIDGE
    PANOPTIC -.-> L_CONSIST
    PANOPTIC -.-> L_PQ

    %% Styling
    classDef input fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px
    classDef backbone fill:#E3F2FD,stroke:#1976D2,stroke-width:2px
    classDef semantic fill:#FFF3E0,stroke:#E65100,stroke-width:2px
    classDef instance fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px
    classDef bridge fill:#E0F7FA,stroke:#00838F,stroke-width:2px
    classDef mamba fill:#FFEBEE,stroke:#C62828,stroke-width:3px
    classDef output fill:#FBE9E7,stroke:#D84315,stroke-width:2px
    classDef loss fill:#E8EAF6,stroke:#3F51B5,stroke-width:1px
    classDef stc fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px

    class RGB,DEPTH input
    class PATCH,TRANS,FEAT backbone
    class SEM_HEAD,SEM_CODE semantic
    class NCUT,INST_FEAT instance
    class PROJ_S,PROJ_F,ALIGNED bridge
    class INTERLEAVE,FWD,BWD,BICMS,DEINTER,FUSED mamba
    class MERGE,PANOPTIC output
    class L_SEM,L_INST,L_BRIDGE,L_CONSIST,L_PQ,L_TOTAL loss
    class DBD,FCC,IDF,MLP,ST_OUT stc
```

