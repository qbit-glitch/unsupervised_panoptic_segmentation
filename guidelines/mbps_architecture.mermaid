## Simplified Data Flow Diagram

```mermaid
%%{init: {'theme': 'base'}}%%

graph LR
    subgraph Phase_A["Phase A: Semantic Foundation"]
        A1["RGB"] --> A2["DINO"] --> A3["Semantic Head"] --> A4["L_semantic"]
    end

    subgraph Phase_B["Phase B: Instance Integration"]
        B1["RGB"] --> B2["DINO"] --> B3["Instance Head"] --> B4["L_instance"]
        B2 --> B5["Semantic Head"]
        B5 --> B6["Gradient Projection"]
        B3 --> B6
    end

    subgraph Phase_C["Phase C: Joint Training"]
        C1["Semantic S"] --> C2["Projection"]
        C3["Instance F"] --> C2
        C2 --> C4["Mamba2 Bridge"]
        C4 --> C5["Inverse Proj"]
        C5 --> C6["Panoptic"]
        C6 --> C7["All Losses"]
    end

    subgraph Phase_D["Phase D: Self-Training"]
        D1["θ_teacher"] --> D2["Pseudo Labels"]
        D2 --> D3["Confidence Filter"]
        D3 --> D4["θ_student"]
        D4 --> D5["EMA Update"]
        D5 --> D1
    end

    Phase_A --> Phase_B --> Phase_C --> Phase_D
```

---

## Mamba2 SSD Internal Structure (TPU-Optimized)

```mermaid
%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#FFEBEE'}}}%%

flowchart TB
    subgraph INPUT_SEQ["Input Sequence"]
        X["x ∈ ℝ^(B×L×D)"]
    end

    subgraph PARAMS["Input-Dependent Parameters"]
        DELTA["Δ = Softplus(Linear(x))"]
        B_PROJ["B = Linear(x)"]
        C_PROJ["C = Linear(x)"]
        A_BAR["Ā = exp(Δ ⊙ A)"]
    end

    subgraph CHUNKING["Chunked Processing (P=128)"]
        CHUNK["Divide into L/P chunks"]
        H_INIT["h₀ = zeros(B, D, N)"]
    end

    subgraph CHUNK_LOOP["For each chunk k"]
        SEMI["Build Semiseparable M_k"]
        H_CONTRIB["y_from_h = h_{k-1} · C_k^T"]
        INTRA["y_intra = M_k · (x_k ⊙ B_k)"]
        Y_K["y_k = y_from_h + y_intra"]
        H_UPDATE["h_k = UpdateState(h_{k-1}, Ā_k, B_k, x_k)"]
    end

    subgraph OUTPUT["Output"]
        CONCAT["y = Concat(y_1, ..., y_{L/P})"]
        RESIDUAL["y = y + D · x"]
    end

    X --> PARAMS
    DELTA --> A_BAR
    X --> CHUNKING
    CHUNK --> CHUNK_LOOP
    H_INIT --> CHUNK_LOOP
    A_BAR --> SEMI
    B_PROJ --> SEMI
    C_PROJ --> SEMI
    SEMI --> INTRA
    H_CONTRIB --> Y_K
    INTRA --> Y_K
    Y_K --> H_UPDATE
    H_UPDATE -->|"next chunk"| H_CONTRIB
    Y_K --> CONCAT
    CONCAT --> RESIDUAL

    style SEMI fill:#EF9A9A,stroke:#C62828
    style INTRA fill:#EF9A9A,stroke:#C62828
    style RESIDUAL fill:#FFCDD2,stroke:#E53935
```

---

## Stuff-Things Classification Pipeline

```mermaid
%%{init: {'theme': 'base'}}%%

flowchart LR
    subgraph INPUTS["Inputs per Semantic Cluster c"]
        SEM["Semantic Mask R_c"]
        DEPTH_MAP["Depth Map D"]
        DINO_F["DINO Features F"]
        INST_M["Instance Masks {m_j}"]
    end

    subgraph CUE1["Cue 1: DBD"]
        SOBEL["Sobel Filter G_d"]
        THRESH["Threshold τ_d"]
        COUNT["Count boundary pixels"]
        DBD_OUT["DBD(c) = boundary/|R_c|"]
        
        DEPTH_MAP --> SOBEL --> THRESH --> COUNT --> DBD_OUT
    end

    subgraph CUE2["Cue 2: FCC"]
        COV_C["Cov(F[R_c])"]
        COV_TOT["Cov(F_total)"]
        RATIO["trace ratio"]
        FCC_OUT["FCC(c) = 1 - ratio"]
        
        DINO_F --> COV_C --> RATIO
        DINO_F --> COV_TOT --> RATIO --> FCC_OUT
    end

    subgraph CUE3["Cue 3: IDF"]
        OVERLAP["Count overlapping instances"]
        AREA["Area of R_c"]
        IDF_OUT["IDF(c) = instances/area"]
        
        INST_M --> OVERLAP --> IDF_OUT
        SEM --> AREA --> IDF_OUT
    end

    subgraph CLASSIFIER["MLP Classifier"]
        CONCAT_CUES["[DBD; FCC; IDF]"]
        MLP["Linear(3,16)→ReLU→Linear(16,8)→ReLU→Linear(8,1)"]
        SIGMOID["σ(·)"]
        DECISION["p(thing|c) > 0.5?"]
        
        DBD_OUT --> CONCAT_CUES
        FCC_OUT --> CONCAT_CUES
        IDF_OUT --> CONCAT_CUES
        CONCAT_CUES --> MLP --> SIGMOID --> DECISION
    end

    subgraph OUTPUT["Classification"]
        THING["Thing Class ✓"]
        STUFF["Stuff Class ✗"]
        DECISION -->|"Yes"| THING
        DECISION -->|"No"| STUFF
    end

    style THING fill:#E8F5E9,stroke:#4CAF50
    style STUFF fill:#ECEFF1,stroke:#607D8B
```

