# Machine override: santosh@100.93.203.100, 2x GTX 1080 Ti (11GB each).
#
# Santosh is VRAM-constrained: bs=1 x accum=16 is mandatory for M2F + ViT-Adapter
# (c2 cross-attn at stride-4 consumes the majority of the 11 GB budget).
#
# Env activation (run BEFORE invoking the launcher):
#   conda activate cups

DATA.ROOT=/media/santosh/Kuldeep/panoptic_segmentation/datasets/cityscapes/
DATA.ROOT_VAL=/media/santosh/Kuldeep/panoptic_segmentation/datasets/cityscapes/
DATA.ROOT_PSEUDO=/media/santosh/Kuldeep/panoptic_segmentation/datasets/cityscapes/cups_pseudo_labels_depthpro_tau020/

TRAINING.BATCH_SIZE=1
TRAINING.ACCUMULATE_GRAD_BATCHES=16

SYSTEM.NUM_WORKERS=2

LOG_ROOT=/home/santosh/experiments/stage2_m2f
