# Machine override: Anydesk (cvpr_ug_5@gpunode2), RTX A6000 48GB.
#
# Sourced by scripts/train_stage2_m2f.sh. Each KEY=VALUE line becomes a
# pair of yacs CLI overrides ("KEY VALUE") appended to train.py, except
# LOG_ROOT which is handled specially (prepended to SYSTEM.LOG_PATH using
# the ablation's RUN_NAME).
#
# Batch geometry (bs=4 x accum=4) matches the in-flight M0 anydesk run.
# Effective batch = 16, same as santosh bs=1 x accum=16.
#
# Env activation (run BEFORE invoking the launcher):
#   module load gcc-9.3.0
#   source ~/umesh/ups_env/bin/activate

DATA.ROOT=/home/cvpr_ug_5/umesh/datasets/cityscapes/
DATA.ROOT_VAL=/home/cvpr_ug_5/umesh/datasets/cityscapes/
DATA.ROOT_PSEUDO=/home/cvpr_ug_5/umesh/datasets/cityscapes/cups_pseudo_labels_depthpro_tau020/

TRAINING.BATCH_SIZE=4
TRAINING.ACCUMULATE_GRAD_BATCHES=4

SYSTEM.NUM_WORKERS=4

# LOG_ROOT is consumed by the bash launcher -- not by yacs.
LOG_ROOT=/home/cvpr_ug_5/umesh/experiments/stage2_m2f
